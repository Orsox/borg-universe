APP_NAME=Borg Universe
APP_VERSION=0.1.0
APP_ENV=local
APP_DEBUG=false
APP_PORT=8000
LOG_LEVEL=INFO

BORG_ROOT=/app/BORG
AGENTS_ROOT=/app/agents
SKILLS_ROOT=/app/skills
WORKFLOWS_ROOT=/app/BORG/workflows
ARTIFACT_ROOT=/app/artifacts
MCP_SERVER_URL=http://mcp:9000
MCP_PORT=9000
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_SIZE=4
WORKER_RUNNING_TASK_TIMEOUT_SECONDS=900
CLAUDE_EXECUTABLE=claude
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_PROJECT_ROOT=/app
WORKBENCH_HOST_ROOT=D:\Workbench
WORKBENCH_CONTAINER_ROOT=/workbench
LLM_TIMEOUT_SECONDS=1800
CLAUDE_TIMEOUT_SECONDS=1800
INSTALL_ARM_GCC=true
INSTALL_EMBEDDED_PY_TOOLS=true
INSTALL_PLATFORMIO=false

# Local Supabase-compatible non-production stack.
# Do not use these values outside local development.
