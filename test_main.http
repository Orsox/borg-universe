Accept: application/json

###

POST http://127.0.0.1:9000/tools/knowledge.search/call
Content-Type: application/json
Accept: application/json

{
  "agent_name": "manual-mcp-test",
  "arguments": {
    "platform": "STM32",
    "peripheral": "SPI",
    "query": "HAL",
    "limit": 5
  }
}

###

POST http://127.0.0.1:9000/tools/project.search/call
Content-Type: application/json
Accept: application/json

{
  "agent_name": "manual-mcp-test",
  "project_id": "local",
  "arguments": {
    "platform": "STM32",
    "peripheral": "SPI",
    "query": "SPI",
    "limit": 5
  }
}

